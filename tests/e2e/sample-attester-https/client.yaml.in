apiVersion: v1
kind: Pod
metadata:
  name: kbs-client
  namespace: trustee-operator-system
spec:
  containers:
  - name: kbs-client
    image: ${CLIENT_IMAGE_NAME}
    imagePullPolicy: IfNotPresent
    command:
      - sleep
      - "360000"
    env:
      - name: RUST_LOG
        value:  info
    volumeMounts:
      - name: ca-certs
        mountPath: /etc/ssl/certs
        readOnly: true
  volumes:
    - name: ca-certs
      hostPath:
        path: /etc/ssl/certs
        type: Directory
